---
// Inlined Story Nook brand-mark + wordmark + "accident-prone" subtitle.
---
<a href="/Accident-Prone-1.21.4/" aria-label="Accident-Prone home" class="brand-link">
  <span class="brand-square" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none">
      <path
        d="M5 8.5a3.5 3.5 0 0 1 3.5-3.5h7A3.5 3.5 0 0 1 19 8.5v9a1.5 1.5 0 0 1-2.4 1.2L12 15.3l-4.6 3.4A1.5 1.5 0 0 1 5 17.5v-9Z"
        fill="#ffffff"
      />
    </svg>
  </span>
  <span class="brand-lockup">
    <span class="brand-word">Story</span>
    <span class="brand-dot" aria-hidden="true">·</span>
    <span class="brand-word">Nook</span>
    <span class="brand-subtitle" aria-hidden="true">accident-prone</span>
  </span>
</a>

<style>
  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--oath-ink);
    text-decoration: none;
  }
  .brand-square {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--oath-pink), var(--oath-lavender));
    box-shadow: 0 4px 14px -4px rgba(74, 51, 86, 0.45);
    flex-shrink: 0;
  }
  .brand-lockup {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    font-weight: 700;
    font-size: 17px;
    letter-spacing: -0.2px;
  }
  .brand-word { color: var(--oath-ink); }
  .brand-dot { color: var(--oath-ink-muted); font-weight: 700; }
  .brand-subtitle {
    margin-left: 8px;
    color: var(--oath-ink-muted);
    font-size: 13px;
    font-weight: 500;
  }
</style>
